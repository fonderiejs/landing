            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"phoneNumber\": \"+9876543210\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Workspace",
      "item": [
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workspaces/{{workspace_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "workspaces",
                "{{workspace_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-WORKSPACE-ID",
                "value": "{{workspace_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Organization Name\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workspaces/{{workspace_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "workspaces",
                "{{workspace_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Directions",
      "item": [
        {
          "name": "Get Directions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/directions?origin=40.7128,-74.0060&destination=40.7580,-73.9855",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "directions"
              ],
              "query": [
                {
                  "key": "origin",
                  "value": "40.7128,-74.0060",
                  "description": "Starting location (address or coordinates)"
                },
                {
                  "key": "destination",
                  "value": "40.7580,-73.9855",
                  "description": "Destination location (address or coordinates)"
                }
              ]
            },
            "description": "Get directions and route information between two locations"
          }
        },
        {
          "name": "Get Distance Matrix",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/directions/matrix?origin=40.7128,-74.0060&destination=40.7580,-73.9855",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "directions",
                "matrix"
              ],
              "query": [
                {
                  "key": "origin",
                  "value": "40.7128,-74.0060",
                  "description": "Starting location"
                },
                {
                  "key": "destination",
                  "value": "40.7580,-73.9855",
                  "description": "Destination location"
                }
              ]
            },
            "description": "Get distance and duration matrix between locations"
          }
        }
      ]
    }
